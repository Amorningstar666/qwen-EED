
  // INDAGACIÓN — lógica de decisiones
  function openDecisionModal() {
    openModal('modal-decision-indagacion');
  }
  
  function toggleDecisionIndagacion(tipo) {
    var causal = document.getElementById('campo-causal-archivo-indagacion');
    causal.style.display = tipo === 'archivo' ? 'block' : 'none';
    document.getElementById('btn-confirmar-decision-indagacion').disabled = false;
    var msgs = {
      abrir: 'Proyectar auto de apertura de investigación disciplinaria',
      archivo: 'Proyectar auto de terminación de indagación previa'
    };
    var btn = document.getElementById('btn-confirmar-decision-indagacion');
    btn.innerHTML = '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg> ' + msgs[tipo];
    // resaltar opción seleccionada
    document.querySelectorAll('[name="decision-indagacion"]').forEach(function(r) {
      var lbl = r.closest('label');
      lbl.style.borderColor = r.checked ? 'var(--azul)' : 'var(--gris-claro)';
      lbl.style.background = r.checked ? '#EBF4FA' : '#FAFBFC';
    });
  }
  
  function confirmarDecisionIndagacion() {
    var sel = document.querySelector('[name="decision-indagacion"]:checked');
    if (!sel) return;
    var toasts = {
      abrir: 'Auto de apertura de investigación disciplinaria proyectado. La persona en averiguación pasa a ser investigado formal.',
      archivo: 'Auto de terminación de indagación previa proyectado. Enviado a revisión.'
    };
    closeModal('modal-decision-indagacion');
    showToast(toasts[sel.value]);
    // resetear
    document.querySelectorAll('[name="decision-indagacion"]').forEach(function(r) { r.checked = false; });
    document.getElementById('campo-causal-archivo-indagacion').style.display = 'none';
    document.getElementById('btn-confirmar-decision-indagacion').disabled = true;
    document.getElementById('btn-confirmar-decision-indagacion').innerHTML = '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg> Proyectar acto';
  }
